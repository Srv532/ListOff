# ─────────────────────────────────────────────────────────────────
# ListOFF — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any real secrets to version control.
# ─────────────────────────────────────────────────────────────────

# SECURITY (#4): GROQ_API_KEY is a SERVER-SIDE-ONLY secret.
# It must NOT use the VITE_ prefix — that would expose it in the client bundle.
# Used by api/index.js (Vercel serverless function) only.
# Get yours at: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# SECURITY (#16 CORS): Comma-separated list of allowed frontend origins.
# Example: https://listoff.vercel.app,https://www.listoff.app
ALLOWED_ORIGINS="http://localhost:3000"

# Optional: Used for Vercel Preview URL access control
# APP_URL is the canonical production URL of this app
APP_URL="http://localhost:3000"

# Optional: Firebase config (if not using firebase-applet-config.json locally)
# These are client-safe public values from Firebase Console > Project Settings.
# VITE_ prefix makes them available to the React frontend bundle.
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_DATABASE_ID="(default)"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
